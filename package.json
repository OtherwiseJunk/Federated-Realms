{
  "name": "federated-realms",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev:server": "bun run --filter realms-server dev",
    "dev:cli": "bun run --filter realms-cli dev",
    "dev:web": "bun run --filter realms-web dev",
    "test": "bun test --recursive",
    "test:unit": "bun test --recursive packages/",
    "test:e2e": "bun test --retry 5 --recursive apps/realms-server/test/",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --deny-warnings packages/ apps/",
    "lint:fix": "oxlint --deny-warnings --fix packages/ apps/",
    "fmt": "oxfmt --write packages/ apps/",
    "fmt:check": "oxfmt --check packages/ apps/",
    "clean": "rm -rf packages/*/dist apps/*/dist"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "unicode-segmenter": "^0.15.0"
  }
}
