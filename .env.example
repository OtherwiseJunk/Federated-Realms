# ──────────────────────────────────────
# Federated Realms — Environment Config
# ──────────────────────────────────────
# Copy to .env and fill in values, or run:
#   ./scripts/bootstrap-pds.sh

# Server
PORT=3000
SERVER_NAME=Federated Realms
SERVER_DESCRIPTION=A mysterious dungeon awaits...
# Number of trusted reverse proxies in front of this server, used to pick the
# real client IP from X-Forwarded-For for auth rate limiting. SECURITY: must match
# your actual proxy count AND the app must NOT be directly reachable — otherwise a
# client can forge X-Forwarded-For and spoof its rate-limit identity. The shipped
# docker-compose binds the app to localhost so only a same-host proxy reaches it,
# which satisfies this. Default 1 (a single host nginx); set to 0 if you expose
# the app directly with no proxy.
TRUSTED_PROXY_HOPS=1
DEFAULT_SPAWN=starter-town:town-square

# PDS (Personal Data Server) — used by docker-compose
PDS_HOSTNAME=localhost
PDS_PORT=2583
PDS_JWT_SECRET=           # generated by bootstrap script
PDS_ADMIN_PASSWORD=       # generated by bootstrap script
PDS_ROTATION_KEY=         # secp256k1 private key hex, generated by bootstrap script

# PDS Email (required by PDS, use dummy values for local dev)
PDS_EMAIL_SMTP_URL=smtp://fake:25
PDS_EMAIL_FROM_ADDRESS=noreply@localhost

# AT Proto — Server Identity
PDS_URL=http://localhost:2583
SERVER_HANDLE=federated-realms.test
SERVER_PASSWORD=          # generated by bootstrap script
SERVER_DID=               # auto-populated on first boot
PUBLIC_URL=http://localhost:3000

# Federation
# trust-all imports remote characters' level/items/gold with no allow-list —
# use only for isolated testing. Sensible default is trust-listed: characters
# from servers in TRUSTED_SERVERS keep their gear, everyone else is stripped.
# Options: trust-all | trust-listed | trust-none | trust-level-cap
TRUST_POLICY=trust-listed
TRUSTED_SERVERS=
MAX_ACCEPTED_LEVEL=50

# Bluesky Bridge (optional)
BSKY_ENABLED=false
BSKY_IDENTIFIER=
BSKY_PASSWORD=
BSKY_SERVICE=https://bsky.social
BSKY_POST_TYPES=chat,shout,event
BSKY_PLAYER_CROSSPOST=true
BSKY_THREAD_REFRESH=60
BSKY_THROTTLE_MS=2000
